{
  "name": "python-browser-lessons",
  "version": "1.0.0",
  "description": "A client-side website for running Python in the browser",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "serve": "http-server ./dist -c-1",
    "lint": "eslint src/ts/**/*.ts",
    "format": "prettier --write \"src/**/*.{ts,html,css}\"",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@types/pyodide": "^0.25.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.9.1",
    "eslint": "^8.56.0",
    "html-webpack-plugin": "^5.6.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mini-css-extract-plugin": "^2.7.7",
    "prettier": "^3.2.4",
    "style-loader": "^3.3.4",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}